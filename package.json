{
  "name": "tradelab",
  "version": "1.2.1",
  "description": "Backtesting toolkit for Node.js with strategy simulation, historical data loading, and report generation",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./src/index.js",
  "types": "./types/index.d.ts",
  "bin": {
    "tradelab": "bin/tradelab.js",
    "tradelab-mcp": "bin/tradelab-mcp.js"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ishsharm0/tradelab.git"
  },
  "homepage": "https://github.com/ishsharm0/tradelab#readme",
  "bugs": {
    "url": "https://github.com/ishsharm0/tradelab/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./data": {
      "types": "./types/data.d.ts",
      "import": "./src/data/index.js",
      "require": "./dist/cjs/data.cjs"
    },
    "./live": {
      "types": "./types/live.d.ts",
      "import": "./src/live/index.js",
      "require": "./dist/cjs/live.cjs"
    },
    "./ta": {
      "types": "./types/ta.d.ts",
      "import": "./src/ta/index.js",
      "require": "./dist/cjs/ta.cjs"
    },
    "./mcp": {
      "types": "./types/mcp.d.ts",
      "import": "./src/mcp/server.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "docs/README.md",
    "docs/api-reference.md",
    "docs/backtest-engine.md",
    "docs/data-reporting-cli.md",
    "docs/examples.md",
    "docs/live-trading.md",
    "docs/mcp.md",
    "docs/research.md",
    "dist",
    "src",
    "types",
    "templates",
    "examples/*.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build-cjs.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepare": "npm run build",
    "test": "node --test"
  },
  "keywords": [
    "trading",
    "backtesting",
    "algorithmic-trading",
    "ohlcv",
    "quant",
    "quantitative-finance",
    "yahoo-finance",
    "trading-strategy",
    "market-data"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.15.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.25.1",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
